# Secrets for the RND environment.
# Copy this file to orphan-scanner.rnd.conf.secrets.tfvars and fill in real values.
# NEVER commit the .secrets.tfvars file - it is gitignored.

# AWS CLI/SSO profile used to deploy the scanner into the HUB account.
# Leave "" to use your default credentials/profile instead.
aws_profile = "<HUB_ACCOUNT_CLI_PROFILE>"
