resource "aws_ami" "ami" {
  name                = var.ami_name
  description         = var.ami_description
  architecture        = var.ami_architecture
  virtualization_type = var.ami_virtualization_type
  imds_support        = var.ami_imds_support
  tags                = var.ami_tags
}
